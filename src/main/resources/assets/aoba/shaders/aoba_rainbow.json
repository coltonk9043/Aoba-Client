{
    "backend": "opengl",
    "name": "Rainbow",
    "description": "Animated rainbow gradient",
    "params": [
        { "type": "time" },
        { "type": "resolution" },
        { "name": "Speed", "type": "float", "default": 1.0, "min": 0.1, "max": 5.0, "step": 0.1 },
        { "name": "Scale", "type": "float", "default": 2.0, "min": 0.5, "max": 10.0, "step": 0.5 },
        { "name": "Saturation", "type": "float", "default": 0.8, "min": 0.0, "max": 1.0, "step": 0.05 },
        { "name": "Brightness", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "step": 0.05 },
        { "name": "Transparency", "type": "float", "default": 1.0, "min": 0.0, "max": 1.0, "step": 0.05 }
    ]
}
