{
    "backend": "opengl",
    "name": "Radial Gradient",
    "description": "Circular gradient radiating from center",
    "params": [
        { "name": "Inner Color", "type": "color", "default": [0.8, 0.8, 1.0, 1.0] },
        { "name": "Outer Color", "type": "color", "default": [0.1, 0.1, 0.3, 1.0] },
        { "name": "Center X", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.05 },
        { "name": "Center Y", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.05 },
        { "name": "Radius", "type": "float", "default": 0.7, "min": 0.1, "max": 2.0, "step": 0.05 }
    ]
}
