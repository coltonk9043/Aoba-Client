{
    "backend": "opengl",
    "name": "Blur Gradient",
    "description": "Blurred game background tinted with a two-color gradient",
    "params": [
        { "type": "time" },
        { "type": "resolution" },
        { "name": "Game", "type": "framebuffer" },
        { "name": "Start Color", "type": "color", "default": [0.2, 0.2, 0.8, 0.8] },
        { "name": "End Color", "type": "color", "default": [0.8, 0.2, 0.2, 0.8] },
        { "name": "Radius", "type": "float", "default": 4.0, "min": 1.0, "max": 64.0, "step": 1.0 },
        { "name": "Quality", "type": "float", "default": 2.0, "min": 1.0, "max": 4.0, "step": 0.5 },
        { "name": "Angle", "type": "float", "default": 0.0, "min": 0.0, "max": 360.0, "step": 15.0 }
    ]
}
