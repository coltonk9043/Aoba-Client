{
    "backend": "opengl",
    "name": "Conical Gradient",
    "description": "Angular sweep gradient around a center point",
    "params": [
        { "name": "Start Color", "type": "color", "default": [1.0, 0.0, 0.0, 1.0] },
        { "name": "End Color", "type": "color", "default": [0.0, 0.0, 1.0, 1.0] },
        { "name": "Start Angle", "type": "float", "default": 0.0, "min": 0.0, "max": 360.0, "step": 15.0 },
        { "name": "Center X", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.05 },
        { "name": "Center Y", "type": "float", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.05 }
    ]
}
