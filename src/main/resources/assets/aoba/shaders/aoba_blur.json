{
    "backend": "opengl",
    "name": "Blur",
    "description": "Blurred game background",
    "params": [
        { "type": "time" },
        { "type": "resolution" },
        { "name": "Game", "type": "framebuffer" },
        { "name": "Tint", "type": "color", "default": [1.0, 1.0, 1.0, 0.8] },
        { "name": "Radius", "type": "float", "default": 4.0, "min": 1.0, "max": 64.0, "step": 1.0 },
        { "name": "Quality", "type": "float", "default": 2.0, "min": 1.0, "max": 4.0, "step": 0.5 }
    ]
}
